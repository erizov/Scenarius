# Application
APP_NAME=Scenarius
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production
APP_HOST=127.0.0.1
APP_PORT=8008

# Database — pick ONE target (see data/postgres_instances.yaml)
# docker  = pgvector/pg16 in Docker on port 5435 (recommended)
# pg16    = native PostgreSQL 16 on port 5434
# pg17    = native PostgreSQL 17 on port 5433
# pg15    = native PostgreSQL 15 on port 5432 (no pgvector)
POSTGRES_TARGET=docker
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_USER=scenarius
POSTGRES_PASSWORD=scenarius
POSTGRES_DB=scenarius

# Or override fully:
# DATABASE_URL=postgresql+psycopg://scenarius:scenarius@localhost:5435/scenarius

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Search
SEARCH_DEFAULT_LANGUAGE=ru
SEARCH_DEFAULT_TIER=1
EMBEDDING_ENABLED=true
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Scrapers
SCRAPER_USER_AGENT=Scenarius/0.2 (https://github.com/scenarius/scenarius; mailto:scenarius@local) Python-httpx
SCRAPER_DELAY_SECONDS=1.0
SCRAPER_TIMEOUT_SECONDS=120
# Optional ingest API keys (enable matching source in data/sources.yaml)
OPENSUBTITLES_API_KEY=
RUSCORPORA_API_KEY=

# LLM story generation (Ollama first, OpenAI fallback)
LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=800
